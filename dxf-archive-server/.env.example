# Postgres 연결 문자열 (Railway Postgres 플러그인이 자동 제공)
DATABASE_URL=postgresql://user:password@host:5432/railway

# 관리자 등록/수정 API용 비밀 토큰 (임의 문자열 생성해서 사용)
ADMIN_TOKEN=devtoken123

# 서버 포트 (Railway가 자동 주입, 로컬 개발 시 직접 지정)
PORT=3000

# CORS 허용 origin (콤마로 구분, 비워두면 모두 허용)
# CORS_ORIGIN=http://localhost:5500,https://example.github.io
